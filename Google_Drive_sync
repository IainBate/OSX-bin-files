#!/bin/bash
# gdrive_sync.sh — Manages a full Google Drive sync cycle: launch → monitor → quit.
#
# Sync detection uses MULTI-SOURCE indicators rather than log-parsing:
#
#   1. Directory Quiescence — checks whether any file in ~/Google Drive/
#      (the synced content directory) has been modified in the last 45 seconds.
#      We monitor the synced content directory rather than the internal DriveFS
#      cache because the cache contains SQLite files (.db, .db-wal, .db-shm)
#      that are written to constantly even when Drive is idle.
#      If files are changing, Drive is still working.
#
#   2. Active Write Handles — runs `lsof -c "Google Drive"` and filters out
#      known internal database files (.db, .db-wal, .db-shm). If any remaining
#      write handles exist, Drive has active I/O.
#
# Both checks must pass (no activity detected) for a single iteration to count
# as "idle." A sustained cooldown counter requires N consecutive idle checks
# (default: 6 checks × 30 s = 3 min) before sync is declared complete. Any
# detected activity resets the counter to zero.
#
# This approach avoids the "thinking state" trap: Google Drive frequently
# enters silent periods during large transfers (API rate-limit backoffs, file
# batching debounces, local metadata indexing via fileproviderd). A single idle
# reading is never trusted — only a sustained period of quiet confirms completion.
#
# Sync is also confirmed only when ALL of the following hold:
#   - No file modifications in ~/Google Drive/ within the last 45 seconds
#   - No active write handles on non-database files
#   - change_ids_up_to_date field from the Drive log (supplementary indicator)
#
# POWER MANAGEMENT: the script uses `caffeinate` to prevent the Mac from
# sleeping, idling, or turning off the display while the sync is active.
# The caffeinate process is killed on script exit (clean or interrupted).
#
# NOTE: drive_fs.txt is still read for supplementary error detection and the
# change_ids_up_to_date indicator. It is no longer the primary sync signal.
#
# NOTE: lsof filtering excludes Google Drive's own locked internal databases
# (.db, .db-wal, .db-shm). Other write handles are treated as meaningful activity.
#
# SYNC_TIMEOUT and LOG_TAIL_LINES were both increased (from 1h/300 lines to
# 2h/500 lines) after a real sync took over 45 minutes to fully reconcile
# while working through a backlog that included several permission-denied
# items -- legitimate, if slow, progress that the original limits were too
# tight to safely accommodate.
#
# NOTE ON COMPLETION STRICTNESS: this script intentionally does NOT treat
# "change_ids_up_to_date=false" as good enough to quit Drive, even if it has
# been false for a while and nothing else is pending. A real sync was observed
# (see project history) holding that field at false for 20+ minutes before
# correctly completing -- so any time-based bypass of that field risks quitting
# Drive mid-sync, which is exactly the failure mode this script exists to avoid.

set -uo pipefail

# ── Configuration ─────────────────────────────────────────────────────────────
readonly DRIVE_APP="Google Drive"
readonly DRIVE_LOG="${HOME}/Library/Application Support/Google/DriveFS/Logs/drive_fs.txt"
readonly DRIVE_SYNCED="${HOME}/Google Drive/"

readonly STARTUP_TIMEOUT=60    # Max seconds to wait for Drive process to appear
readonly LOG_WAIT_TIMEOUT=180  # Max seconds between diagnostic dumps while waiting for the first log entry
readonly SYNC_TIMEOUT=7200     # Max seconds before giving up on sync (2 hours)
readonly POLL_INTERVAL=30      # Seconds between sync-state checks
readonly COOLDOWN_THRESHOLD=10  # Consecutive idle checks required before declaring sync complete
                                # Extended from 6 (3 min) to 10 (5 min) to avoid quitting during
                                # Drive's silent backoff/debounce periods where nothing writes
                                # for a few minutes but sync is not actually complete.
readonly MIN_MONITOR_DURATION=120  # Minimum seconds before trusting any idle reading
                                    # (guards against Drive's initial startup burst)
readonly QUIESCENT_WINDOW=45   # Seconds of no file modification to consider directory "quiet"
readonly LOG_TAIL_LINES=500    # Lines to inspect per check (~50 min of state blocks at 2-min intervals)
readonly QUIT_LOG_FRESHNESS=300 # Seconds before Drive log is considered stale (5 min)
                               # Drive writes a state block every ~2 min; if the log hasn't
                               # been updated in 5 min, Drive has stopped writing blocks.
readonly QUIT_GRACE=60         # Seconds to pause after sync complete before quitting
                               # Extended from 10s — Drive stops writing to its log after sync
                               # completes, so the log becomes stale after ~2 min. A 60s grace
                               # ensures we wait long enough for idle detection to trigger
                               # the quit sequence, giving Drive time to finish processing.
readonly QUIT_TIMEOUT=30       # Max seconds to wait for Drive to quit cleanly before warning
readonly POST_IDLE_GRACE=1800   # Extra seconds after cooldown to let Drive's internal queues drain
                                # Extended to 30 min — Drive was observed still syncing 16 min
                                # after idle detection. The file I/O checks pass before Drive
                                # finishes syncing internally. This grace period covers that gap.
readonly STUCK_THRESHOLD=600   # Seconds of unchanged sync state before warning (10 min)

# All output goes to stdout AND this file; delete the file to disable logging.
readonly SCRIPT_LOG="${HOME}/Library/Logs/gdrive_sync.log"

# Lock file — prevents two instances running concurrently.
readonly LOCK_FILE="${TMPDIR:-/tmp}/gdrive_sync.lock"

# Caffeinate PID — killed on exit to release power assertions.
CAFFEENATE_PID=""

# UTC launch time — used to ignore state blocks predating this script run.
SCRIPT_START=$(date -u '+%Y-%m-%dT%H:%M:%S')
readonly SCRIPT_START

# ── Helpers ───────────────────────────────────────────────────────────────────
log() {
    local msg="[$(date '+%H:%M:%S')] $*"
    echo "$msg"
    printf '%s\n' "$msg" >> "$SCRIPT_LOG" 2>/dev/null || true
}

die() {
    log "ERROR: $*" >&2
    exit 1
}

cleanup() {
    # Kill caffeinate if still running — releases power assertions.
    if [[ -n "${CAFFEENATE_PID:-}" ]] && kill -0 "$CAFFEENATE_PID" 2>/dev/null; then
        kill "$CAFFEENATE_PID" 2>/dev/null || true
    fi
    rm -rf "$LOCK_FILE" 2>/dev/null || true
}

is_drive_running() {
    pgrep -qf "/Applications/Google Drive.app"
}

# ── Sync State Detection (multi-source) ───────────────────────────────────────
# Returns 0 if Drive appears idle, 1 if active, 2 on error.
#
# Three independent checks, all must pass for "idle":
#   1. Directory quiescence — no file modifications in DriveFS within QUIESCENT_WINDOW
#   2. No active write handles — lsof shows no writes to non-database files
#   3. change_ids_up_to_date — supplementary log indicator (if log is available)
#
# If ANY check indicates activity, Drive is considered busy.
# If ANY check errors, the script is conservative and treats Drive as active.
check_sync_state() {
    local is_idle=1  # Default: assume active (conservative)

    # Check 1: Is Drive even running?
    if ! is_drive_running; then
        log "Google Drive is not running."
        return 0  # No process = no sync
    fi

    # Check 2: Directory quiescence — has anything in the synced content
    # directory been modified recently?  We monitor ~/Google Drive/ (the
    # user-facing synced content) rather than the internal DriveFS cache,
    # because the cache contains SQLite files (.db, .db-wal, .db-shm) that
    # are written to constantly even when Drive is idle.
    local modified=""
    if [[ -d "$DRIVE_SYNCED" ]]; then
        modified=$(find "$DRIVE_SYNCED" -type f \
            -mmin -"${QUIESCENT_WINDOW}" \
            2>/dev/null | head -1)
    fi

    if [[ -n "$modified" ]]; then
        log "Directory not quiescent: $modified modified within last ${QUIESCENT_WINDOW}s"
        return 1
    fi

    # Check 3: Active write handles on non-database files
    # Filter out Google Drive's own locked internal databases (.db, .db-wal, .db-shm)
    # and keep only write handles to other files.
    local write_handles
    write_handles=$(lsof -c "Google Drive" -a -w 2>/dev/null | \
        awk 'NR>1 && $8=="WRITE" {
            path = $NF
            # Skip database files: .db, .db-wal, .db-shm
            if (path ~ /\.db$/ || path ~ /\.db-wal$/ || path ~ /\.db-shm$/) next
            print path
        }' | head -1)

    if [[ -n "$write_handles" ]]; then
        log "Active write handle: $write_handles"
        return 1
    fi

    # NOTE: State block format (as of 2026):
    #   operation_queue_size, all_downloads, unique_user_requested_op_count,
    #   change_ids_up_to_date, largest_local_change_id, fetching_changes
    #
    # change_ids_up_to_date is the most reliable sync completion indicator.
    # When false, Drive has NOT finished syncing even if operation_queue_size
    # and all_downloads are both 0. The sync engine reports idle while the
    # mirror subsystem is still processing changes (10-16+ min lag observed).
    #
    # fetching_changes == true means the sync engine is actively fetching
    # changes from the server — a strong signal that sync is in progress.
    #
    # File I/O checks (directory quiescence + write handles) are the primary
    # sync signals. change_ids_up_to_date and fetching_changes are used as
    # supplementary indicators: if either shows activity, Drive is considered
    # busy even if file I/O is quiet.

    # Supplementary: check state block for change_ids_up_to_date and
    # fetching_changes. These are reliable indicators that the sync engine
    # has NOT finished even if file I/O is quiet (mirror subsystem lag).
    if [[ -f "$DRIVE_LOG" ]]; then
        local log_age
        log_age=$(( $(date +%s) - $(stat -f "%m" "$DRIVE_LOG" 2>/dev/null || echo 0) ))
        if (( log_age < QUIT_LOG_FRESHNESS )); then
            # Parse the last state block for change_ids_up_to_date
            local change_ids
            change_ids=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /change_ids_up_to_date:/{print $NF; found=0}' | tail -1)
            if [[ "$change_ids" == "false" ]]; then
                log "State block: change_ids_up_to_date=false (sync not complete)."
                return 1
            fi

            # Parse fetching_changes — true means sync engine is actively fetching
            local fetching
            fetching=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /fetching_changes:/{print $NF; found=0}' | tail -1)
            if [[ "$fetching" == "true" ]]; then
                log "State block: fetching_changes=true (sync engine active)."
                return 1
            fi
        fi
    fi

    # All checks passed — Drive appears idle.
    return 0
}

# ── Error Detection (supplementary) ────────────────────────────────────────────
# Scans the Drive log for known error patterns. Returns a summary string
# or "none" if nothing found. This is the SAME logic as the original script
# but now used for context, not as the primary sync signal.
detect_errors() {
    if [[ ! -f "$DRIVE_LOG" ]]; then
        echo "none"
        return
    fi

    python3 - "$DRIVE_LOG" "$LOG_TAIL_LINES" 2>/dev/null << 'PYEOF'
import sys, re
from collections import Counter


def scan_errors(tail):
    """Scans the given lines for known error patterns and returns a short,
    human-readable summary string (or 'none' if nothing found).

    Covers two distinct patterns seen in Drive's log:
      1. "... due to non-retriable error: REASON" -- a single-line pattern
         from file_provider_change_replayer.cc, logged when Drive gives up
         retrying a specific change (e.g., an item it can no longer access).
      2. "cloud_get_failures { key: \"...\" value { status: X reason: \"Y\" } }"
         -- a multi-line block logged when a server-side fetch fails outright
         (e.g., PERMISSION_DENIED). Not covered by pattern 1.
    """
    non_retriable_count = 0
    non_retriable_reasons = set()

    for line in tail:
        m = re.search(r'non-retriable error:\s*([^:]+)', line)
        if m:
            non_retriable_count += 1
            non_retriable_reasons.add(m.group(1).strip())

    permission_statuses = []
    i = 0
    while i < len(tail):
        if 'cloud_get_failures' in tail[i]:
            status = None
            j = i + 1
            while j < len(tail) and j < i + 8:
                sm = re.search(r'status:\s*(\w+)', tail[j])
                if sm:
                    status = sm.group(1)
                if '}' in tail[j] and status is not None:
                    break
                j += 1
            if status:
                permission_statuses.append(status)
            i = max(j, i + 1)
            continue
        i += 1

    parts = []
    if non_retriable_count:
        reasons = ', '.join(sorted(non_retriable_reasons)) if non_retriable_reasons else 'unspecified'
        parts.append(f'{non_retriable_count} non-retriable change-replay error(s) [{reasons}]')

    if permission_statuses:
        counts = Counter(permission_statuses)
        breakdown = ', '.join(f'{n}x {status}' for status, n in counts.most_common())
        parts.append(f'{len(permission_statuses)} cloud fetch failure(s) [{breakdown}]')

    return '; '.join(parts) if parts else 'none'


def main():
    log_file   = sys.argv[1]
    tail_lines = int(sys.argv[2])

    try:
        with open(log_file, errors='replace') as f:
            lines = f.readlines()
    except OSError:
        print('none')
        return

    tail = lines[-tail_lines:]
    print(scan_errors(tail))


try:
    sys.exit(main())
except Exception:
    print('parser error')
    sys.exit(1)
PYEOF
}

# ── Traps ─────────────────────────────────────────────────────────────────────
trap 'cleanup' EXIT
trap 'echo; log "Script interrupted. ${DRIVE_APP} is still running."; exit 1' INT TERM

# ── 1. Environment checks ──────────────────────────────────────────────────────
[[ "$(uname)" == "Darwin" ]] || die "This script requires macOS."

command -v python3 &>/dev/null || \
    die "python3 is required but not found. Install via: xcode-select --install"

if [[ ! -d "/Applications/Google Drive.app" ]] && \
   [[ ! -d "${HOME}/Applications/Google Drive.app" ]]; then
    die "Google Drive is not installed (checked /Applications and ~/Applications)."
fi

# ── 2. Single-instance lock ────────────────────────────────────────────────────
if ! mkdir "$LOCK_FILE" 2>/dev/null; then
    existing_pid=$(cat "$LOCK_FILE/pid" 2>/dev/null || echo "unknown")
    die "Another instance is already running (PID: ${existing_pid})." \
        "Remove ${LOCK_FILE} manually if it is stale."
fi
echo "$$" > "$LOCK_FILE/pid"

log "=== gdrive_sync started (PID $$) ==="

# ── 3. Launch caffeinate (anti-sleep) ─────────────────────────────────────────
if command -v caffeinate &>/dev/null; then
    caffeinate -u -d &
    CAFFEENATE_PID=$!
    log "Power assertions active (caffeinate PID ${CAFFEENATE_PID})."
else
    log "WARNING: caffeinate not found — system may sleep during sync."
fi

# ── 4. Launch Google Drive ────────────────────────────────────────────────────
if is_drive_running; then
    log "Google Drive is already running — proceeding to sync monitoring."
else
    log "Launching ${DRIVE_APP}..."
    open -a "${DRIVE_APP}" || die "Failed to launch ${DRIVE_APP}. Check it is installed correctly."
fi

# ── 5. Wait for the Drive process to appear ───────────────────────────────────
log "Waiting for ${DRIVE_APP} process (up to ${STARTUP_TIMEOUT}s)..."
startup_elapsed=0
until is_drive_running; do
    if (( startup_elapsed >= STARTUP_TIMEOUT )); then
        die "Drive process did not appear within ${STARTUP_TIMEOUT}s." \
            "It may have failed to launch or crashed immediately."
    fi
    sleep 5
    startup_elapsed=$(( startup_elapsed + 5 ))
done
log "Drive process is running."

# ── 6. Monitor sync state ──────────────────────────────────────────────────────
log "Monitoring sync (multi-source detection; timeout: ${SYNC_TIMEOUT}s)..."
log "Script log: ${SCRIPT_LOG}"

sync_elapsed=0
log_wait_start=$(date +%s)
first_state_seen=0         # set to 1 once DriveFS directory becomes available
consecutive_idle=0         # cooldown counter — must reach COOLDOWN_THRESHOLD
sync_in_progress_since=0   # timestamp when sync was first detected
last_stuck_warn=0          # timestamp of last stuck warning (rate-limit)
errors_ever_seen=0         # set to 1 after the first non-"none" error summary
last_change_id=""          # most recently observed largest_local_change_id
change_id_stable_since=0   # timestamp since last_change_id last changed
max_checks=$(( SYNC_TIMEOUT / POLL_INTERVAL ))

while true; do
    # Check if Drive is still running
    if ! is_drive_running; then
        if (( sync_elapsed >= MIN_MONITOR_DURATION )); then
            log "Google Drive stopped after ${sync_elapsed}s."
            break
        else
            die "Google Drive stopped unexpectedly after only ${sync_elapsed}s."
        fi
    fi

    # Check for sync errors (supplementary context)
    error_msg=$(detect_errors)
    if [[ "$error_msg" != "none" ]] && (( errors_ever_seen == 0 )); then
        log "NOTE: Sync-related errors detected in Drive's log: ${error_msg}"
        log "      This can explain a slow sync (Drive may be repeatedly retrying"
        log "      inaccessible items). Search ${DRIVE_LOG} for these patterns,"
        log "      or check Drive's web UI for items you may have lost access to."
        errors_ever_seen=1
    fi

    # Check sync state (multi-source)
    if check_sync_state; then
        (( consecutive_idle++ ))
        log "Idle check ${consecutive_idle}/${COOLDOWN_THRESHOLD} (no activity detected)."
    else
        consecutive_idle=0
        sync_in_progress_since=$(( sync_in_progress_since == 0 ? $(date +%s) : sync_in_progress_since ))
        in_progress_secs=$(( $(date +%s) - sync_in_progress_since ))
        in_progress_min=$(( in_progress_secs / 60 ))

        # Track largest_local_change_id for stuck detection
        if [[ -f "$DRIVE_LOG" ]]; then
            local_change_id=$(grep -o 'largest_local_change_id: [0-9]*' "$DRIVE_LOG" 2>/dev/null | tail -1 | awk '{print $NF}')
            if [[ -n "$local_change_id" && "$local_change_id" != "$last_change_id" ]]; then
                last_change_id="$local_change_id"
                change_id_stable_since=$(date +%s)
            fi
        fi

        # Stuck detection — warn after STUCK_THRESHOLD seconds of sync
        now=$(date +%s)
        if (( in_progress_secs >= STUCK_THRESHOLD )) && \
           (( now - last_stuck_warn >= STUCK_THRESHOLD )); then
            log "WARNING: Sync has been in progress for ${in_progress_min} min with no completion."

            if [[ -n "$last_change_id" ]]; then
                stable_min=$(( (now - change_id_stable_since) / 60 ))
                if (( stable_min >= 5 )); then
                    log "         largest_local_change_id has been static at ${last_change_id} for ~${stable_min} min."
                    log "         This suggests Drive may be wedged, not just slow."
                else
                    log "         largest_local_change_id is advancing (now ${last_change_id})."
                    log "         Drive appears to be actively working through a backlog."
                fi
            fi

            if [[ "$error_msg" != "none" ]]; then
                log "         Errors: ${error_msg}"
                log "         Search ${DRIVE_LOG} for these patterns to identify affected items."
            else
                log "         No errors detected; Drive may simply have a large backlog to process."
            fi
            last_stuck_warn=$now
        else
            remaining=$(( max_checks - (sync_elapsed / POLL_INTERVAL) - 1 ))
            (( remaining < 0 )) && remaining=0
            log "Syncing (${in_progress_min} min elapsed). ${remaining} checks left until timeout."
        fi
    fi

    # Check cooldown threshold
    if (( consecutive_idle >= COOLDOWN_THRESHOLD )); then
        log "Sync complete — ${COOLDOWN_THRESHOLD} consecutive idle checks passed."
        log "Waiting ${POST_IDLE_GRACE}s for Drive's internal queues to drain..."

        # Drive can continue internal processing for 5-10+ minutes after
        # file I/O stops. We wait the full grace period, then re-check
        # sync state. If Drive resumed syncing, reset and wait again.
        drain_start=$(date +%s)
        grace_end=$(( drain_start + POST_IDLE_GRACE ))
        while true; do
            # Check if grace period expired
            drain_elapsed=$(( $(date +%s) - drain_start ))
            if (( drain_elapsed >= POST_IDLE_GRACE )) && (( $(date +%s) >= grace_end )); then
                # Re-check: is Drive still syncing?
                if ! check_sync_state; then
                    log "Drive is syncing again after grace period — resetting idle counter."
                    consecutive_idle=0
                    break
                fi
                log "Drive still idle after grace period — proceeding to quit."
                break
            fi
            # Check if log has become stale during grace period — if so,
            # extend the deadline to account for mirror subsystem processing lag.
            if [[ -f "$DRIVE_LOG" ]]; then
                log_age=$(( $(date +%s) - $(stat -f "%m" "$DRIVE_LOG" 2>/dev/null || echo 0) ))
                if (( log_age > QUIT_LOG_FRESHNESS )); then
                    # Log went stale — mirror subsystem may still be processing.
                    # Extend grace period by (time since log went stale + buffer)
                    # to ensure we wait long enough for the mirror subsystem to finish.
                    local stale_duration=$(( log_age - QUIT_LOG_FRESHNESS ))
                    local extension=$(( stale_duration + 600 ))  # 10 min buffer
                    grace_end=$(( grace_start + drain_elapsed + extension ))
                    log "Log stale for ${log_age}s — extending grace period by $(( extension / 60 )) min."
                fi
            fi

            # If the log is fresh, check the state block for all indicators.
            if [[ -f "$DRIVE_LOG" ]]; then
                log_age=$(( $(date +%s) - $(stat -f "%m" "$DRIVE_LOG" 2>/dev/null || echo 0) ))
                if (( log_age < QUIT_LOG_FRESHNESS )); then
                    # Parse the last state block for all sync indicators.
                    op_queue=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                        awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /operation_queue_size:/{print $NF; found=0}' | tail -1)
                    downloads=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                        awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /all_downloads:/{print $NF; found=0}' | tail -1)
                    change_ids=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                        awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /change_ids_up_to_date:/{print $NF; found=0}' | tail -1)
                    fetching=$(tail -500 "$DRIVE_LOG" 2>/dev/null | \
                        awk '/Sync engine activity state:/{found=1; next} found && /^$/{found=0} found && /fetching_changes:/{print $NF; found=0}' | tail -1)

                    if [[ -n "$op_queue" && "$op_queue" != "0" ]]; then
                        log "Drive has ${op_queue} pending operation(s) in state block — resetting idle counter."
                        consecutive_idle=0
                        break
                    fi
                    if [[ -n "$downloads" && "$downloads" != "0" ]]; then
                        log "Drive has ${downloads} pending download(s) in state block — resetting idle counter."
                        consecutive_idle=0
                        break
                    fi
                    if [[ "$change_ids" == "false" ]]; then
                        log "State block: change_ids_up_to_date=false — sync not complete, extending grace period by 10 min."
                        consecutive_idle=0
                        grace_end=$(( $(date +%s) + 600 ))
                        break
                    fi
                    if [[ "$change_ids" == "true" ]]; then
                        log "State block: change_ids_up_to_date=true — sync confirmed complete, exiting grace period early."
                        break
                    fi
                    if [[ "$fetching" == "true" ]]; then
                        log "State block: fetching_changes=true — sync engine actively fetching."
                        consecutive_idle=0
                        break
                    fi
                fi
            fi
            sleep 30
        done
        break
    fi

    # Check timeout
    if (( sync_elapsed >= SYNC_TIMEOUT )); then
        {
            log "Timed out after ${SYNC_TIMEOUT}s. Diagnostic — last 15 lines of Drive log:"
            if [[ "$error_msg" != "none" ]]; then
                log "Errors detected during monitoring: ${error_msg}"
            fi
            if [[ -f "$DRIVE_LOG" ]]; then
                tail -15 "$DRIVE_LOG"
            else
                echo "  (log file not found at: ${DRIVE_LOG})"
            fi
        } >&2
        die "Sync timed out after ${SYNC_TIMEOUT}s. Google Drive will not be quit."
    fi

    sleep "$POLL_INTERVAL"
    sync_elapsed=$(( sync_elapsed + POLL_INTERVAL ))
done

# ── 7. Grace period ────────────────────────────────────────────────────────────
log "Pausing ${QUIT_GRACE}s before quitting (guarding against late-arriving changes)..."
sleep "$QUIT_GRACE"

# ── 8. Quit Google Drive ──────────────────────────────────────────────────────
log "Quitting ${DRIVE_APP}..."
quit_failed=0

# Google Drive shows a confirmation dialog when quitting during active sync:
#   "Quit Google Drive? Files are still syncing. ..."
# The AppleScript quit returns failure when this dialog appears. We handle it
# by retrying the quit after a grace period (letting Drive finish its work),
# and if it still can't quit, falling back to SIGTERM.

attempt=0
max_quit_attempts=3
quit_wait=10  # Start with 10s grace, increase each attempt

while is_drive_running && (( attempt < max_quit_attempts )); do
    (( attempt++ ))
    log "Quit attempt ${attempt}/${max_quit_attempts}..."

    if osascript -e "quit app \"${DRIVE_APP}\"" 2>/dev/null; then
        log "Quit command accepted."
        break
    else
        log "Quit rejected — Drive is still syncing. Waiting ${quit_wait}s for queues to drain..."
        sleep "$quit_wait"
        quit_wait=$(( quit_wait + 20 ))  # Exponential back-off
    fi
done

# Final graceful attempt via SIGTERM if still running
if is_drive_running; then
    log "Drive still running after ${max_quit_attempts} quit attempts — sending SIGTERM..."
    pkill -TERM -f "/Applications/Google Drive.app" 2>/dev/null || true

    quit_elapsed=0
    while is_drive_running && (( quit_elapsed < QUIT_TIMEOUT )); do
        sleep 2
        quit_elapsed=$(( quit_elapsed + 2 ))
    done
fi

if is_drive_running; then
    log "WARNING: ${DRIVE_APP} is still running after quit attempts."
    log "         It may be processing a final write. Check Activity Monitor if it persists."
    EXIT_REASON="Sync completed, but ${DRIVE_APP} did not quit after ${max_quit_attempts} attempts."
else
    log "${DRIVE_APP} has exited cleanly."
    EXIT_REASON="Sync completed and ${DRIVE_APP} quit cleanly."
fi

log "----------------------------------------------------------"
log "FINISHED: ${EXIT_REASON}"
log "============================================================"

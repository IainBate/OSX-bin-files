Rme=`basename "$1"`
echo "CONVERT 1 - " $1 $2 $3 $4 $tmp_filename
PID=$$
nice -n 20 ffmpeg -i "$1" -sn -map_chapters -1 -map_metadata -1 -map 0:v:0 -map 0:a:0 -metadata title="$2" -metadata genre="$4" -vf scale=1024:-2 -vcodec libx264 -b:v 900k -acodec libfdk_aac -b:a 96k -f mp4 -threads 0 /tmp/tmp_$PID.mp4 </dev/null

if [ -f /tmp/tmp_$PID.mp4 ]; then
	mv /tmp/tmp_$PID.mp4 "$3"
	if [ "$1" != "$3" ]; then
		rm "$1"
	fi
else
   	echo "File /tmp/tmp_$PID.mp4 does not exist."
fi


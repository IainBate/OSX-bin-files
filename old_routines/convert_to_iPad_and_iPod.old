# cat the files in, e.g. cat X.mp4|convert_to_iPad title or cat VTS_01_[1234].VOB|convert_to_iPad title
# e.g. cat VTS_01_[1234].VOB|convert_to_iPad "Star_Wars" 

nice -n 20 ffmpeg -i - -s 1024x768 -acodec libfaac -ar 48000 -ab 96k -ac 2 -vcodec libx264 -b:v 900k "$1_iPad.mp4"
nice -n 20 ffmpeg -i "$1_iPad.mp4" -s 480x320 -acodec libfaac -ar 48000 -ab 96k -ac 2 -vcodec libx264 -b:v 300k "$1.mp4"

# ffmpeg -y -i "$1" -s 1024x768 -vf 'pad=1024:768:0:0:black' -vcodec libx264 -b 900k -f mp4 -acodec libfaac -ab 96k -threads 0 -vpre hq temp.mp4
# mv temp.mp4 "`echo $1|sed "s/.wmv/.mp4/"|sed "s/.VOB/.mp4/"`" 

# to convert a dvd use file VTS_01.VOB as input

# nice -n 20 ffmpeg -y -i "$1" -acodec libfaac -ar 48000 -ab 128k -ac 2 -s 960x640 -vcodec libx264 -b 1200k -flags +loop+mv4 -cmp 256 -partitions -parti8x8-parti4x4-partp8x8-partp4x4-partb8x8 -subq 7 -trellis 1 -refs 5 -coder 0 -me_range 16 -keyint_min 25 -sc_threshold 40 -i_qfactor 0.71 -bt 1200k -maxrate 1200k -bufsize 1200k -rc_eq 'blurCplx^(1-qComp)' -qcomp 0.6 -qmin 10 -qmax 51 -qdiff 4 -level 30 -aspect 16:9 -r 30 -g 90 -async 2 "$2"

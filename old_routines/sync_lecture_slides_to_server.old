mkdir /tmp/lecture_slides/CRSY\ lecture\ notes/seminars
# mkdir /tmp/lecture_slides/DART

# CRSY
rsync --rsh=ssh --archive --delete --verbose --times /Volumes/GoogleDrive/My\ Drive/lecturing_stuff/archive_material/CRS/BBC_videos/*.mp4 /tmp/lecture_slides/CRSY\ lecture\ notes/BBC_videos/
rsync --rsh=ssh --archive --delete --verbose --times /Volumes/GoogleDrive/My\ Drive/lecturing_stuff/CRS/L*.pptx /tmp/lecture_slides/CRSY\ lecture\ notes/

# rsync --rsh=ssh --archive --delete --verbose --times /Volumes/GoogleDrive/My\ Drive/lecturing_stuff/CRS/seminars/ /tmp/lecture_slides/CRSY/seminars/
rsync --rsh=ssh --archive --delete --verbose --times /Volumes/GoogleDrive/My\ Drive/lecturing_stuff/CRS/CRSY\ -\ 2019\ 0\ -\ CS\ Exams/\[003\]\ Presentation/Submissions\ between\ 2019\ 12\ 04\ 12:00\ and\ 2020\ 01\ 27\ 13:37/  /tmp/lecture_slides/CRSY\ seminars/

